# Backend (FastAPI)
# Copy to .env (or export in your shell). Do not commit real secrets.

SUPABASE_URL=
# From: Project Settings → API → Project API keys → "service_role" (the long eyJ... JWT)
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET is not needed — auth verification uses the JWKS endpoint at
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json, which works for ES256/RS256/HS256.

# Frontend (Vite)
# Create web/.env.local with the following (values from Supabase project settings):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
